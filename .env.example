# Supabase Projekt „web-app“ (Service Role nur auf dem Server)
SUPABASE_URL=https://DEINE_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Login
DASHBOARD_USER=
# Entweder bcrypt-Hash (empfohlen für Vercel) …
# DASHBOARD_PASSWORD_HASH=
# … oder Klartext nur lokal (nie committen):
# DASHBOARD_PASSWORD=

# JWT-Signatur für Cookie-Session (mind. 32 Zeichen, zufällig)
SESSION_SECRET=

# Optional: 3 feste Demo-Zeilen oben in der Liste (UI-Test), Wert 1 oder true
# DASHBOARD_DEMO_TREFFER=1
